# =============================================
# NUTRISABOR — Variáveis de Ambiente (EXEMPLO)
# Copie este arquivo para .env e preencha com
# os valores reais. Nunca compartilhe o .env.
# =============================================

# Banco de Dados
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=cozinha_industrial
DB_POOL_SIZE=5

# Aplicação Flask
# Gere uma chave com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui

# Cookie de sessão só por HTTPS. Em PRODUÇÃO (com HTTPS) defina 1.
# Em desenvolvimento local (http://localhost) deixe 0.
SESSION_COOKIE_SECURE=0

# Debug do Flask. NUNCA use 1 em produção (expõe debugger com execução de
# código). Só faz efeito ao rodar `python app.py` localmente.
FLASK_DEBUG=0

# E-mail (Resend — https://resend.com)
RESEND_API_KEY=re_sua_chave_aqui
MAIL_FROM=NutriSabor <onboarding@resend.dev>
